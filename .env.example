# Required — F5 XC tenant
F5XC_API_URL=https://your-tenant.console.ves.volterra.io
F5XC_API_TOKEN=your-api-token

# Required — Slack app
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Optional — tuning
LOG_LEVEL=info
CACHE_WARM_TTL=300
CACHE_STATIC_TTL=3600
NLP_THRESHOLD=0.65
PORT=3000
